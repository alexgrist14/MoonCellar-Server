faro.receiver "frontend" {
  server {
    listen_address       = "0.0.0.0"
    listen_port          = 12347
    cors_allowed_origins = ["*"]
  }

  output {
    logs   = [loki.write.default.receiver]
    traces = []
  }
}

loki.write "default" {
  endpoint {
    url = "http://host.containers.internal:3100/loki/api/v1/push"
  }
}
